[{"id": 0, "text": "\u529b\u95a2\u4fc2\u304c\u306f\u3063\u304d\u308a\u3057\u305f\u95a2\u4fc2\u304c\u597d\u304d\uff1f", "hint": "\u4f8b\uff1a\u4e3b\u5f93\u30fb\u652f\u914d\u88ab\u652f\u914d\u30fb\u96c7\u7528\u30fb\u7acb\u5834\u306e\u4e0a\u4e0b\u95a2\u4fc2\u304c\u3042\u308b", "variants": ["\u4e0a\u4e0b\u95a2\u4fc2\u30fb\u4e3b\u5f93\u95a2\u4fc2\u304c\u306f\u3063\u304d\u308a\u3057\u305f\u95a2\u4fc2\u304c\u597d\u304d\uff1f"]}, {"id": 1, "text": "\u7981\u65ad\u30fb\u793e\u4f1a\u7684\u306b\u8a31\u3055\u308c\u306a\u3044\u95a2\u4fc2\u306b\u60f9\u304b\u308c\u308b\uff1f", "hint": "\u4f8b\uff1a\u5e2b\u5f1f\u30fb\u8fd1\u89aa\u30fb\u8eab\u5206\u5dee\u30fb\u793e\u4f1a\u7684\u306bNG\u306a\u30bf\u30d6\u30fc\u306a\u95a2\u4fc2", "variants": ["\u30bf\u30d6\u30fc\u306a\u95a2\u4fc2\u30fb\u3057\u3066\u306f\u3044\u3051\u306a\u3044\u604b\u304c\u597d\u304d\uff1f"]}, {"id": 2, "text": "\u7570\u5e38\u306a\u307b\u3069\u306e\u57f7\u7740\u30fb\u4f9d\u5b58\u304c\u597d\u304d\uff1f", "hint": "\u4f8b\uff1a\u300c\u304a\u524d\u3060\u3051\u300d\u300c\u624b\u653e\u305b\u306a\u3044\u300d\u7a2e\u985e\u306e\u7570\u5e38\u306a\u57f7\u7740", "variants": ["\u72c2\u611b\u30fb\u7570\u5e38\u306a\u307e\u3067\u306e\u57f7\u7740\u304c\u597d\u304d\uff1f"]}, {"id": 3, "text": "\u53d7\u3051\u8eab\u30fb\u3055\u308c\u308b\u5074\u306e\u7acb\u5834\u304c\u597d\u304d\uff1f", "hint": "\u4f8b\uff1a\u5f15\u3063\u5f35\u3089\u308c\u308b\u30fb\u5b88\u3089\u308c\u308b\u30fb\u3055\u308c\u308b\u304c\u307e\u307e\u306e\u7acb\u5834", "variants": []}, {"id": 4, "text": "\u300c\u6240\u6709\u7269\u300d\u306e\u3088\u3046\u306b\u6271\u308f\u308c\u308b\u95a2\u4fc2\u304c\u597d\u304d\uff1f", "hint": "\u4f8b\uff1a\u300c\u4ffa\u306e\u3082\u306e\u300d\u300c\u96e2\u3055\u306a\u3044\u300d\u3068\u3044\u3046\u6240\u6709\u30fb\u652f\u914d\u306e\u611f\u899a", "variants": []}, {"id": 5, "text": "\u7518\u304f\u3066\u5e78\u305b\u306a\u95a2\u4fc2\u304c\u597d\u304d\uff1f", "hint": "\u4f8b\uff1a\u6eba\u611b\u30fb\u7518\u3005\u30fb\u30cf\u30c3\u30d4\u30fc\u30a8\u30f3\u30c9\u304c\u524d\u63d0\u306e\u5e78\u305b\u306a\u95a2\u4fc2", "variants": []}, {"id": 6, "text": "\u5ac9\u59ac\u3084\u72ec\u5360\u6b32\u304c\u5f37\u3044\u95a2\u4fc2\u304c\u597d\u304d\uff1f", "hint": "\u4f8b\uff1a\u300c\u4ed6\u306e\u8ab0\u306b\u3082\u6e21\u3055\u306a\u3044\u300d\u5f37\u3044\u72ec\u5360\u6b32\u30fb\u5ac9\u59ac", "variants": []}, {"id": 7, "text": "\u6050\u6016\u3084\u75db\u307f\u304c\u5feb\u611f\u30fb\u8208\u596e\u3068\u7d50\u3073\u3064\u3044\u3066\u3044\u308b\u306e\u304c\u597d\u304d\uff1f", "hint": "\u4f8b\uff1aSM\u30fb\u62d8\u675f\u30fb\u4f53\u7f70\u7684\u306a\u523a\u6fc0\u304c\u95a2\u4fc2\u306b\u7d61\u3080", "variants": []}, {"id": 8, "text": "\u88cf\u5207\u308a\u3084\u55aa\u5931\u611f\u3092\u3068\u3082\u306a\u3046\u604b\u611b\u304c\u597d\u304d\uff1f", "hint": "\u4f8b\uff1aNTR\u30fb\u5931\u604b\u30fb\u5927\u5207\u306a\u4eba\u304c\u596a\u308f\u308c\u308b\u55aa\u5931\u3068\u88cf\u5207\u308a", "variants": []}, {"id": 9, "text": "\u540c\u6027\u540c\u58eb\u306e\u604b\u611b\u30fb\u89aa\u5bc6\u306a\u95a2\u4fc2\u304c\u597d\u304d\uff1f", "hint": "\u4f8b\uff1aBL\u30fb\u767e\u5408\u30fb\u540c\u6027\u540c\u58eb\u306e\u89aa\u5bc6\u306a\u95a2\u4fc2", "variants": []}, {"id": 10, "text": "\u4eba\u9593\u3067\u306a\u3044\u5b58\u5728\uff08\u602a\u7269\u30fb\u6a5f\u68b0\u30fb\u795e\u306a\u3069\uff09\u3068\u306e\u604b\u611b\u304c\u597d\u304d\uff1f", "hint": "\u4f8b\uff1a\u30b1\u30e2\u30ce\u30fb\u5438\u8840\u9b3c\u30fb\u30a2\u30f3\u30c9\u30ed\u30a4\u30c9\u30fb\u795e\u306a\u3069\u975e\u4eba\u9593\u3068\u306e\u604b\u611b", "variants": ["\u30b9\u30c8\u30fc\u30ab\u30fc\u30fb\u72ec\u5360\u6b32\u304c\u5f37\u3059\u304e\u308b\u30ad\u30e3\u30e9\u304c\u597d\u304d\uff1f"]}, {"id": 11, "text": "\u5916\u898b\u304c\u4eba\u9593\u3068\u306f\u3063\u304d\u308a\u7570\u306a\u308b\u76f8\u624b\u304c\u597d\u304d\uff1f", "hint": "\u4f8b\uff1a\u8033\u30fb\u5c3b\u5c3e\u30fb\u9c57\u30fb\u7ffc\u30fb\u89d2\u306a\u3069\u4eba\u9593\u3068\u7570\u306a\u308b\u5916\u898b\u3092\u6301\u3064\u76f8\u624b", "variants": []}, {"id": 12, "text": "\u304b\u306a\u308a\u5e74\u4e0a\u30fb\u6210\u719f\u3057\u305f\u5927\u4eba\u306b\u60f9\u304b\u308c\u308b\uff1f", "hint": "\u4f8b\uff1a10\u6b73\u4ee5\u4e0a\u306e\u5e74\u306e\u5dee\u30fb\u5927\u4eba\u306e\u843d\u3061\u7740\u304d\u30fb\u6210\u719f\u3057\u305f\u9b45\u529b", "variants": []}, {"id": 13, "text": "\u304b\u306a\u308a\u5e74\u4e0b\u30fb\u307e\u305f\u306f\u5e7c\u304f\u898b\u3048\u308b\u76f8\u624b\u306b\u60f9\u304b\u308c\u308b\uff1f", "hint": "\u4f8b\uff1a\u5e74\u4e0b\u30fb\u5e7c\u3044\u5916\u898b\u30fb\u7121\u90aa\u6c17\u3055\u3068\u306e\u30ae\u30e3\u30c3\u30d7", "variants": []}, {"id": 14, "text": "\u5e7c\u3044\u9803\u304b\u3089\u306e\u7e01\u304c\u3042\u308b\u76f8\u624b\u3068\u306e\u95a2\u4fc2\u304c\u597d\u304d\uff1f", "hint": "\u4f8b\uff1a\u5e7c\u99b4\u67d3\u30fb\u5e7c\u5c11\u671f\u304b\u3089\u306e\u7e01\u30fb\u5b50\u4f9b\u306e\u9803\u304b\u3089\u77e5\u3063\u3066\u3044\u308b\u76f8\u624b", "variants": []}, {"id": 15, "text": "\u6027\u5225\u304c\u66d6\u6627\u30fb\u307e\u305f\u306f\u9014\u4e2d\u3067\u5909\u308f\u308b\u8a2d\u5b9a\u304c\u597d\u304d\uff1f", "hint": "\u4f8b\uff1a\u6027\u8ee2\u63db\u30fb\u7537\u306e\u5a18\u30fb\u30b8\u30a7\u30f3\u30c0\u30fc\u30ec\u30b9\u306a\u30ad\u30e3\u30e9\u30fb\u6027\u5225\u4e0d\u660e", "variants": []}, {"id": 16, "text": "1\u4eba\u30923\u4eba\u4ee5\u4e0a\u304c\u540c\u6642\u306b\u597d\u304d\u306b\u306a\u308b\u72b6\u6cc1\u304c\u597d\u304d\uff1f", "hint": "\u4f8b\uff1a\u30cf\u30fc\u30ec\u30e0\u30fb\u9006\u30cf\u30fc\u30ec\u30e0\u30fb\u8907\u6570\u4eba\u304b\u3089\u540c\u6642\u306b\u6c42\u3081\u3089\u308c\u308b", "variants": []}, {"id": 17, "text": "\u7570\u4e16\u754c\u30fb\u30d5\u30a1\u30f3\u30bf\u30b8\u30fc\u306e\u4e16\u754c\u304c\u821e\u53f0\u306a\u306e\u304c\u597d\u304d\uff1f", "hint": "\u4f8b\uff1a\u30c9\u30e9\u30b4\u30f3\u30fb\u9b54\u6cd5\u30fb\u8ee2\u751f\u30fb\u5225\u4e16\u754c\u89b3\u304c\u524d\u63d0\u306e\u8a2d\u5b9a", "variants": []}, {"id": 18, "text": "\u5b66\u6821\u30fb\u8077\u5834\u306a\u3069\u73fe\u5b9f\u7684\u306a\u65e5\u5e38\u304c\u821e\u53f0\u306a\u306e\u304c\u597d\u304d\uff1f", "hint": "\u4f8b\uff1a\u6559\u5ba4\u30fb\u30aa\u30d5\u30a3\u30b9\u30fb\u65e5\u5e38\u751f\u6d3b\u306e\u4e2d\u3067\u306e\u604b\u611b", "variants": []}, {"id": 19, "text": "\u4e3b\u4eba\u516c\u304c\u7279\u5225\u306a\u5f37\u3055\u30fb\u5727\u5012\u7684\u306a\u80fd\u529b\u3092\u6301\u3064\u306e\u304c\u597d\u304d\uff1f", "hint": "\u4f8b\uff1a\u6700\u5f37\u30c1\u30fc\u30c8\u30fb\u8ee2\u751f\u7279\u5178\u30fb\u5727\u5012\u7684\u306a\u80fd\u529b\u3067\u7121\u53cc\u3059\u308b\u4e3b\u4eba\u516c", "variants": []}, {"id": 20, "text": "\u6700\u521d\u306f\u5bfe\u7acb\u30fb\u6575\u5bfe\u3057\u3066\u3044\u305f\u304c\u5f90\u3005\u306b\u60f9\u304b\u308c\u5408\u3046\u6d41\u308c\u304c\u597d\u304d\uff1f", "hint": "\u4f8b\uff1a\u30e9\u30a4\u30d0\u30eb\u2192\u604b\u4eba\u30fb\u72ac\u733f\u306e\u4ef2\u304c\u604b\u611b\u306b\u30fb\u6575\u5bfe\u304b\u3089\u59cb\u307e\u308b\u95a2\u4fc2", "variants": []}, {"id": 21, "text": "\u5fa9\u8b90\u3084\u5831\u5fa9\u304c\u52d5\u6a5f\u306b\u306a\u3063\u3066\u3044\u308b\u306e\u304c\u597d\u304d\uff1f", "hint": "\u4f8b\uff1a\u3056\u307e\u3041\u5c55\u958b\u30fb\u5fa9\u8b90\u3092\u679c\u305f\u3057\u306a\u304c\u3089\u60f9\u304b\u308c\u3066\u3044\u304f", "variants": []}, {"id": 22, "text": "\u62d8\u675f\u30fb\u7269\u7406\u7684\u306b\u52d5\u304d\u3092\u5236\u9650\u3055\u308c\u308b\u72b6\u6cc1\u304c\u597d\u304d\uff1f", "hint": "\u4f8b\uff1a\u7e04\u30fb\u9396\u30fb\u76e3\u7981\u30fb\u9003\u3052\u3089\u308c\u306a\u3044\u72b6\u6cc1\u306b\u7f6e\u304b\u308c\u308b", "variants": []}, {"id": 23, "text": "\u610f\u8b58\u3084\u601d\u8003\u3092\u5916\u90e8\u304b\u3089\u30b3\u30f3\u30c8\u30ed\u30fc\u30eb\u3055\u308c\u308b\u306e\u304c\u597d\u304d\uff1f", "hint": "\u4f8b\uff1a\u50ac\u7720\u30fb\u6d17\u8133\u30fb\u601d\u8003\u652f\u914d\u3067\u81ea\u5206\u3067\u306f\u306a\u3044\u884c\u52d5\u3092\u3068\u308b", "variants": []}, {"id": 24, "text": "\u8907\u6570\u4eba\u304c\u540c\u6642\u306b\u7d61\u3080\u72b6\u6cc1\u304c\u597d\u304d\uff1f", "hint": "\u4f8b\uff1a3P\u30fb\u4e71\u4ea4\u30fb\u8907\u6570\u306e\u76f8\u624b\u3068\u540c\u6642\u9032\u884c\u3059\u308b\u72b6\u6cc1", "variants": []}, {"id": 25, "text": "\u7363\u5316\u30fb\u5909\u8eab\u30fb\u6027\u8ee2\u63db\u306a\u3069\u4f53\u304c\u5909\u5316\u3059\u308b\u306e\u304c\u597d\u304d\uff1f", "hint": "\u4f8b\uff1a\u4eba\u304c\u7363\u306b\u306a\u308b\u30fb\u6027\u5225\u304c\u5909\u308f\u308b\u30fb\u5225\u306e\u59ff\u306b\u5909\u8eab\u3059\u308b", "variants": []}, {"id": 26, "text": "\u8840\u7e01\u30fb\u5bb6\u65cf\u306b\u8fd1\u3044\u9593\u67c4\u304c\u95a2\u4fc2\u3059\u308b\u306e\u304c\u597d\u304d\uff1f", "hint": "\u4f8b\uff1a\u5144\u59b9\u30fb\u89aa\u5b50\u30fb\u5bb6\u65cf\u306b\u8fd1\u3044\u9593\u67c4\u304c\u95a2\u4fc2\u306b\u7d61\u3080", "variants": []}, {"id": 27, "text": "\u4e3b\u4eba\u3068\u4f7f\u7528\u4eba\u306e\u3088\u3046\u306a\u96c7\u7528\u30fb\u7acb\u5834\u5dee\u306e\u3042\u308b\u95a2\u4fc2\u304c\u597d\u304d\uff1f", "hint": "\u4f8b\uff1a\u4e3b\u5f93\u30fb\u57f7\u4e8b\u30fb\u30e1\u30a4\u30c9\u30fb\u96c7\u3046\u5074\u3068\u96c7\u308f\u308c\u308b\u5074\u306e\u95a2\u4fc2", "variants": []}, {"id": 28, "text": "\u6a5f\u68b0\u30fb\u4eba\u5de5\u77e5\u80fd\u30fb\u30ed\u30dc\u30c3\u30c8\u304c\u76f8\u624b\u306a\u306e\u304c\u597d\u304d\uff1f", "hint": "\u4f8b\uff1a\u30a2\u30f3\u30c9\u30ed\u30a4\u30c9\u30fbAI\u30fb\u30ed\u30dc\u30c3\u30c8\u306a\u3069\u6a5f\u68b0\u7684\u306a\u76f8\u624b", "variants": []}, {"id": 29, "text": "\u898b\u305f\u76ee\u304c\u53ef\u611b\u3089\u3057\u3044\u30fb\u5e7c\u3044\u30fb\u5c0f\u67c4\u306a\u76f8\u624b\u304c\u597d\u304d\uff1f", "hint": "\u4f8b\uff1a\u5c0f\u3055\u3044\u30fb\u5e7c\u3044\u9854\u7acb\u3061\u30fb\u53ef\u611b\u3089\u3057\u3044\u5916\u898b\u306e\u76f8\u624b", "variants": []}, {"id": 30, "text": "\u4f53\u683c\u5dee\u30fb\u8eab\u9577\u5dee\u304c\u5f37\u8abf\u3055\u308c\u308b\u95a2\u4fc2\u304c\u597d\u304d\uff1f", "hint": "\u4f8b\uff1a\u5927\u304d\u306a\u624b\u3067\u5305\u307e\u308c\u308b\u30fb\u8eab\u9577\u5dee30cm\u4ee5\u4e0a\u30fb\u4f53\u683c\u5dee\u3067\u5b88\u3089\u308c\u308b\u611f", "variants": []}, {"id": 31, "text": "\u5f37\u304f\u30fb\u4e3b\u4f53\u7684\u306b\u52d5\u304f\u5973\u6027\u304c\u4e2d\u5fc3\u306a\u306e\u304c\u597d\u304d\uff1f", "hint": "\u4f8b\uff1a\u5f37\u5f15\u306a\u5973\u6027\u30fb\u5973\u9a0e\u58eb\u30fb\u4e3b\u5c0e\u6a29\u3092\u6301\u3064\u30d2\u30ed\u30a4\u30f3\u304c\u6d3b\u8e8d\u3059\u308b", "variants": []}, {"id": 32, "text": "\u6700\u521d\u306f\u5f31\u3044\u30fb\u8650\u3052\u3089\u308c\u308b\u7acb\u5834\u304b\u3089\u59cb\u307e\u308b\u306e\u304c\u597d\u304d\uff1f", "hint": "\u4f8b\uff1a\u3056\u307e\u3041\u524d\u306e\u8650\u3052\u3089\u308c\u30b7\u30fc\u30f3\u30fb\u4e0b\u524b\u4e0a\u30fb\u5f31\u3044\u7acb\u5834\u304b\u3089\u306e\u9006\u8ee2", "variants": []}, {"id": 33, "text": "\u9b54\u6cd5\u30fb\u8d85\u80fd\u529b\u306a\u3069\u8d85\u5e38\u306e\u529b\u304c\u767b\u5834\u3059\u308b\u306e\u304c\u597d\u304d\uff1f", "hint": "\u4f8b\uff1a\u9b54\u6cd5\u30fb\u5ff5\u529b\u30fb\u7279\u6b8a\u80fd\u529b\u304c\u65e5\u5e38\u3084\u95a2\u4fc2\u306b\u7d61\u3080", "variants": []}, {"id": 34, "text": "\u6c38\u9060\u306e\u547d\u30fb\u4e0d\u8001\u30fb\u6642\u3092\u8d85\u3048\u305f\u5b58\u5728\u304c\u597d\u304d\uff1f", "hint": "\u4f8b\uff1a\u5438\u8840\u9b3c\u30fb\u795e\u30fb\u4f55\u767e\u5e74\u3082\u751f\u304d\u3066\u3044\u308b\u4e0d\u8001\u4e0d\u6b7b\u306e\u5b58\u5728", "variants": []}, {"id": 35, "text": "\u30af\u30fc\u30eb\u3067\u7121\u53e3\u3060\u304c\u5b9f\u306f\u6df1\u3044\u611f\u60c5\u3092\u6301\u3064\u76f8\u624b\u304c\u597d\u304d\uff1f", "hint": "\u4f8b\uff1a\u30af\u30fc\u30c7\u30ec\u30fb\u7121\u8868\u60c5\u3060\u3051\u3069\u5185\u5fc3\u3067\u306f\u6df1\u304f\u60f3\u3063\u3066\u3044\u308b\u76f8\u624b", "variants": []}, {"id": 36, "text": "\u732e\u8eab\u7684\u30fb\u3068\u3053\u3068\u3093\u5c3d\u304f\u3057\u3066\u304f\u308c\u308b\u76f8\u624b\u304c\u597d\u304d\uff1f", "hint": "\u4f8b\uff1a\u300c\u3042\u306a\u305f\u306e\u305f\u3081\u306a\u3089\u4f55\u3067\u3082\u300d\u3068\u5168\u529b\u3067\u5c3d\u304f\u3057\u3066\u304f\u308c\u308b\u76f8\u624b", "variants": []}, {"id": 37, "text": "\u300c\u79d8\u5bc6\u30fb\u96a0\u3057\u4e8b\u300d\u304c\u95a2\u4fc2\u306e\u91cd\u8981\u306a\u8981\u7d20\u306b\u306a\u308b\u306e\u304c\u597d\u304d\uff1f", "hint": "\u4f8b\uff1a\u30d0\u30ec\u305f\u3089\u7d42\u308f\u308b\u79d8\u5bc6\u30fb\u4e8c\u4eba\u3060\u3051\u306e\u96a0\u3057\u4e8b\u304c\u95a2\u4fc2\u306e\u6838\u5fc3", "variants": []}, {"id": 38, "text": "\u4eba\u9593\u4ee5\u5916\u306e\u7a2e\u65cf\u304c\u5171\u5b58\u3059\u308b\u30d5\u30a1\u30f3\u30bf\u30b8\u30fc\u4e16\u754c\u304c\u597d\u304d\uff1f", "hint": "\u4f8b\uff1a\u30a8\u30eb\u30d5\u30fb\u7363\u4eba\u30fb\u7adc\u304c\u540c\u3058\u4e16\u754c\u306b\u5b58\u5728\u3059\u308b\u7570\u7a2e\u65cf\u5171\u5b58\u4e16\u754c", "variants": []}, {"id": 39, "text": "\u666e\u6bb5\u306f\u51b7\u9759\u3060\u304c\u81ea\u5206\u306b\u3060\u3051\u7279\u5225\u306a\u53cd\u5fdc\u3092\u3059\u308b\u76f8\u624b\u304c\u597d\u304d\uff1f", "hint": "\u4f8b\uff1a\u4ed6\u4eba\u306b\u306f\u7121\u95a2\u5fc3\u306a\u306e\u306b\u81ea\u5206\u306b\u3060\u3051\u30c7\u30ec\u308b\u30fb\u7279\u5225\u6271\u3044", "variants": []}, {"id": 40, "text": "\u30d1\u30fc\u30c8\u30ca\u30fc\u304c\u8ab0\u304b\u306b\u596a\u308f\u308c\u308b\u30fb\u95a2\u4fc2\u3092\u6301\u3064\u5c55\u958b\u304c\u597d\u304d\uff1f", "hint": "\u4f8b\uff1aNTR\u30fb\u5bdd\u53d6\u3089\u308c\u30fb\u5927\u5207\u306a\u4eba\u304c\u4ed6\u306e\u8ab0\u304b\u3068\u95a2\u4fc2\u3092\u6301\u3064\u5c55\u958b", "variants": []}, {"id": 41, "text": "\u30d1\u30fc\u30c8\u30ca\u30fc\u3092\u4ed6\u8005\u306b\u5dee\u3057\u51fa\u3059\u30fb\u898b\u305b\u308b\u5074\u306e\u7acb\u5834\u304c\u597d\u304d\uff1f", "hint": "\u4f8b\uff1a\u5bdd\u53d6\u3089\u305b\u30fb\u898b\u3089\u308c\u308b\u8208\u596e\u30fb\u5dee\u3057\u51fa\u3059\u5074\u306e\u5feb\u611f", "variants": []}, {"id": 42, "text": "\u598a\u5a20\u30fb\u5b50\u5b6b\u3092\u6b8b\u3059\u3053\u3068\u304c\u30c6\u30fc\u30de\u306b\u306a\u308b\u306e\u304c\u597d\u304d\uff1f", "hint": "\u4f8b\uff1a\u5b55\u307e\u305b\u30fb\u7a2e\u4ed8\u3051\u30fb\u5b50\u4f5c\u308a\u304c\u7269\u8a9e\u306e\u91cd\u8981\u306a\u30c6\u30fc\u30de", "variants": []}, {"id": 43, "text": "\u4ed6\u4eba\u306e\u76ee\u304c\u3042\u308b\u5834\u6240\u3067\u306e\u7f9e\u6065\u30fb\u9732\u51fa\u304c\u597d\u304d\uff1f", "hint": "\u4f8b\uff1a\u516c\u8846\u306e\u9762\u524d\u30fb\u898b\u3089\u308c\u3066\u3044\u308b\u72b6\u6cc1\u30fb\u4eba\u76ee\u304c\u3042\u308b\u5834\u6240\u3067\u306e\u7f9e\u6065", "variants": []}, {"id": 44, "text": "\u6642\u9593\u505c\u6b62\u30fb\u5922\u30fb\u7570\u7a7a\u9593\u306a\u3069\u73fe\u5b9f\u304b\u3089\u5207\u308a\u96e2\u3055\u308c\u305f\u72b6\u6cc1\u304c\u597d\u304d\uff1f", "hint": "\u4f8b\uff1a\u6642\u304c\u6b62\u307e\u3063\u305f\u4e16\u754c\u30fb\u5922\u306e\u4e2d\u30fb\u73fe\u5b9f\u304b\u3089\u9694\u7d76\u3055\u308c\u305f\u7a7a\u9593", "variants": []}, {"id": 45, "text": "\u524d\u4e16\u306e\u8a18\u61b6\u30fb\u751f\u307e\u308c\u5909\u308f\u308a\u30fb\u5bbf\u547d\u306e\u7e01\u304c\u597d\u304d\uff1f", "hint": "\u4f8b\uff1a\u8ee2\u751f\u30fb\u8f2a\u5efb\u30fb\u524d\u4e16\u304b\u3089\u306e\u7d04\u675f\u3084\u7e01\u304c\u73fe\u4e16\u306b\u5f71\u97ff\u3059\u308b", "variants": []}, {"id": 46, "text": "\u751f\u7269\u5b66\u7684\u306a\u672c\u80fd\u30fb\u30d5\u30a7\u30ed\u30e2\u30f3\u30fb\u756a\uff08\u3064\u304c\u3044\uff09\u306e\u6982\u5ff5\u304c\u597d\u304d\uff1f", "hint": "\u4f8b\uff1a\u30aa\u30e1\u30ac\u30d0\u30fc\u30b9\u30fb\u756a\u306e\u672c\u80fd\u30fb\u6297\u3048\u306a\u3044\u751f\u7269\u7684\u306a\u5f15\u304d\u5bc4\u305b", "variants": []}, {"id": 47, "text": "\u4f53\u306e\u30b5\u30a4\u30ba\u304c\u6975\u7aef\u306b\u5909\u5316\u3059\u308b\uff08\u7e2e\u5c0f\u30fb\u5de8\u5927\u5316\uff09\u306e\u304c\u597d\u304d\uff1f", "hint": "\u4f8b\uff1a\u624b\u306e\u3072\u3089\u30b5\u30a4\u30ba\u306b\u306a\u308b\u30fb\u5de8\u4eba\u306b\u62b1\u304d\u304b\u304b\u3048\u3089\u308c\u308b", "variants": []}, {"id": 48, "text": "\u60aa\u5f79\u306b\u8ee2\u751f\u3057\u7834\u6ec5\u30d5\u30e9\u30b0\u3092\u56de\u907f\u3059\u308b\u8a2d\u5b9a\u304c\u597d\u304d\uff1f", "hint": "\u4f8b\uff1a\u60aa\u5f79\u4ee4\u5b22\u306b\u8ee2\u751f\u3057\u3066\u6b7b\u4ea1\u30a8\u30f3\u30c9\u3092\u56de\u907f\u3057\u3088\u3046\u3068\u3059\u308b\u8a2d\u5b9a", "variants": []}, {"id": 49, "text": "\u5206\u8eab\u30fb\u30af\u30ed\u30fc\u30f3\u30fb\u540c\u3058\u5916\u898b\u306e\u5b58\u5728\u304c\u8907\u6570\u767b\u5834\u3059\u308b\u306e\u304c\u597d\u304d\uff1f", "hint": "\u4f8b\uff1a\u3082\u3046\u4e00\u4eba\u306e\u81ea\u5206\u30fb\u30af\u30ed\u30fc\u30f3\u30fb\u53cc\u5b50\u304c\u7d61\u3080\u8907\u96d1\u306a\u95a2\u4fc2", "variants": []}, {"id": 50, "text": "\u85ac\u30fb\u5a9a\u85ac\u3067\u7406\u6027\u3084\u610f\u601d\u304c\u5931\u308f\u308c\u308b\u72b6\u6cc1\u304c\u597d\u304d\uff1f", "hint": "\u4f8b\uff1a\u5a9a\u85ac\u30fb\u85ac\u7269\u30fb\u7406\u6027\u304c\u6d88\u3048\u3066\u672c\u80fd\u304c\u51fa\u308b\u72b6\u6cc1", "variants": []}, {"id": 51, "text": "\u5bc6\u5ba4\u30fb\u7262\u7344\u30fb\u9003\u3052\u3089\u308c\u306a\u3044\u7a7a\u9593\u306b\u9589\u3058\u8fbc\u3081\u3089\u308c\u308b\u72b6\u6cc1\u304c\u597d\u304d\uff1f", "hint": "\u4f8b\uff1a\u7121\u4eba\u5cf6\u30fb\u5730\u4e0b\u5ba4\u30fb\u5916\u306b\u51fa\u3089\u308c\u306a\u3044\u4e8c\u4eba\u304d\u308a\u306e\u9589\u9396\u7a7a\u9593", "variants": []}, {"id": 52, "text": "\u9b54\u6cd5\u5c11\u5973\u304c\u5815\u843d\u30fb\u6c5a\u67d3\u30fb\u7a62\u308c\u3066\u3044\u304f\u8a2d\u5b9a\u304c\u597d\u304d\uff1f", "hint": "\u4f8b\uff1a\u6e05\u7d14\u306a\u9b54\u6cd5\u5c11\u5973\u304c\u95c7\u306b\u67d3\u307e\u308b\u30fb\u5815\u843d\u30fb\u6c5a\u67d3\u3055\u308c\u3066\u3044\u304f\u5c55\u958b", "variants": []}, {"id": 53, "text": "\u5148\u8f29\u5f8c\u8f29\u30fb\u4e0a\u53f8\u90e8\u4e0b\u306e\u95a2\u4fc2\u304b\u3089\u604b\u611b\u304c\u751f\u307e\u308c\u308b\u306e\u304c\u597d\u304d\uff1f", "hint": "\u4f8b\uff1a\u8077\u5834\u30fb\u90e8\u6d3b\u3067\u306e\u5148\u8f29\u5f8c\u8f29\u30fb\u4e0a\u53f8\u3068\u90e8\u4e0b\u306e\u95a2\u4fc2\u304b\u3089\u604b\u611b\u3078", "variants": []}, {"id": 54, "text": "\u5973\u6027\u5074\u304c\u7a4d\u6975\u7684\u306b\u4e3b\u5c0e\u6a29\u3092\u63e1\u308a\u30ea\u30fc\u30c9\u3059\u308b\u306e\u304c\u597d\u304d\uff1f", "hint": "\u4f8b\uff1a\u5973\u6027\u304b\u3089\u544a\u767d\u30fb\u5973\u6027\u304c\u5f15\u3063\u5f35\u308b\u30fb\u9006\u62bc\u3057\u30fb\u5973\u6027\u4e3b\u5c0e\u306e\u604b\u611b", "variants": []}, {"id": 55, "text": "\u611f\u60c5\u304c\u4e00\u65b9\u901a\u884c\u30fb\u7247\u601d\u3044\u7684\u306a\u8981\u7d20\u304c\u597d\u304d\uff1f", "hint": "\u4f8b\uff1a\u5831\u308f\u308c\u306a\u3044\u7247\u60f3\u3044\u3001\u632f\u308a\u5411\u304b\u306a\u3044\u76f8\u624b\u3078\u306e\u57f7\u7740", "variants": []}, {"id": 56, "text": "\u611f\u60c5\u3084\u95a2\u4fc2\u304c\u6fc0\u3057\u304f\u30fb\u6975\u7aef\u306a\u306e\u304c\u597d\u304d\uff1f", "hint": "\u4f8b\uff1a\u72c2\u611b\u3001\u618e\u3057\u307f\u304c\u611b\u306b\u5909\u308f\u308b\u3001\u611f\u60c5\u306e\u7206\u767a\u30b7\u30fc\u30f3", "variants": ["\u611f\u60c5\u3084\u611b\u60c5\u304c\u7206\u767a\u7684\u30fb\u6975\u7aef\u306a\u306e\u304c\u597d\u304d\uff1f"]}, {"id": 57, "text": "\u7d14\u7c8b\u30fb\u6e05\u3089\u304b\u306a\u5b58\u5728\u304c\u5815\u3061\u308b\u30fb\u6c5a\u3055\u308c\u308b\u306e\u304c\u597d\u304d\uff1f", "hint": "\u4f8b\uff1a\u8056\u5973\u304c\u95c7\u306b\u67d3\u307e\u308b\u3001\u7121\u57a2\u306a\u5b58\u5728\u304c\u5815\u843d\u3059\u308b", "variants": []}, {"id": 58, "text": "\u547d\u304c\u3051\u30fb\u5371\u967a\u3068\u96a3\u308a\u5408\u308f\u305b\u306e\u72b6\u6cc1\u304c\u597d\u304d\uff1f", "hint": "\u4f8b\uff1a\u6226\u5834\u3067\u306e\u7d46\u3001\u6b7b\u3092\u524d\u306b\u3057\u305f\u544a\u767d", "variants": []}, {"id": 59, "text": "\u7acb\u5834\u3084\u95a2\u4fc2\u6027\u304c\u9006\u8ee2\u3059\u308b\u306e\u304c\u597d\u304d\uff1f", "hint": "\u4f8b\uff1a\u652f\u914d\u8005\u304c\u88ab\u652f\u914d\u8005\u306b\u3001\u5f37\u8005\u304c\u5f31\u8005\u306b\u306a\u308b", "variants": []}, {"id": 60, "text": "\u5171\u4f9d\u5b58\u30fb\u96e2\u308c\u3089\u308c\u306a\u3044\u95a2\u4fc2\u304c\u597d\u304d\uff1f", "hint": "\u4f8b\uff1a\u304a\u4e92\u3044\u304c\u3044\u306a\u3044\u3068\u751f\u304d\u3066\u3044\u3051\u306a\u3044\u3001\u6bd2\u306e\u3088\u3046\u306a\u95a2\u4fc2", "variants": ["\u304a\u4e92\u3044\u3092\u4f9d\u5b58\u3057\u3042\u3046\u30fb\u96e2\u308c\u3089\u308c\u306a\u3044\u95a2\u4fc2\u304c\u597d\u304d\uff1f"]}, {"id": 61, "text": "\u7cbe\u795e\u7684\u306a\u7e4b\u304c\u308a\u304c\u8089\u4f53\u3088\u308a\u91cd\u8996\u3055\u308c\u308b\u306e\u304c\u597d\u304d\uff1f", "hint": "\u4f8b\uff1a\u9b42\u306e\u7e4b\u304c\u308a\u3001\u8a00\u8449\u3088\u308a\u76ee\u3067\u8a9e\u308b\u95a2\u4fc2", "variants": []}, {"id": 62, "text": "\u6b32\u671b\u3084\u885d\u52d5\u304c\u6291\u3048\u304d\u308c\u306a\u3044\u30fb\u672c\u80fd\u7684\u306a\u95a2\u4fc2\u304c\u597d\u304d\uff1f", "hint": "\u4f8b\uff1a\u7406\u6027\u304c\u5439\u304d\u98db\u3076\u77ac\u9593\u3001\u672c\u80fd\u306b\u5f93\u3046\u611b", "variants": []}, {"id": 63, "text": "\u5973\u6027\u5411\u3051\u30b3\u30f3\u30c6\u30f3\u30c4\uff08BL\u30fb\u4e59\u5973\u30b2\u30fc\u30e0\u306a\u3069\uff09\u306b\u99b4\u67d3\u307f\u304c\u3042\u308b\uff1f", "hint": "BL\u30fb\u4e59\u5973\u30b2\u30fc\u30e0\u30fbTL\u306a\u3069\u5973\u6027\u5411\u3051\u4f5c\u54c1", "variants": []}, {"id": 64, "text": "\u7537\u6027\u5411\u3051\u30b3\u30f3\u30c6\u30f3\u30c4\u306b\u99b4\u67d3\u307f\u304c\u3042\u308b\uff1f", "hint": "\u30a8\u30ed\u30b2\u30fc\u30fb\u30e9\u30ce\u30d9\u30fb\u30cf\u30fc\u30ec\u30e0\u7cfb\u306a\u3069\u7537\u6027\u5411\u3051\u4f5c\u54c1", "variants": []}, {"id": 65, "text": "\u653b\u3081\u30fb\u53d7\u3051\u3067\u3044\u3046\u3068\u53d7\u3051\u5074\u306b\u611f\u60c5\u79fb\u5165\u3057\u3084\u3059\u3044\uff1f", "hint": "\u653b\u3081\uff1d\u30ea\u30fc\u30c9\u3059\u308b\u5074\u3001\u53d7\u3051\uff1d\u3055\u308c\u308b\u5074", "variants": []}, {"id": 66, "text": "\u30b9\u30ab\u30fc\u30c8\u3088\u308a\u30ba\u30dc\u30f3\u304c\u597d\u304d\uff1f", "hint": "\u30d5\u30a1\u30c3\u30b7\u30e7\u30f3\u3084\u666e\u6bb5\u306e\u597d\u307f\u3068\u3057\u3066", "variants": []}, {"id": 67, "text": "\u30ea\u30fc\u30c9\u3059\u308b\u3088\u308a\u5f15\u3063\u5f35\u3089\u308c\u308b\u65b9\u304c\u597d\u304d\uff1f", "hint": "\u604b\u611b\u3067\u3082\u65e5\u5e38\u3067\u3082\u3001\u4e3b\u5c0e\u6a29\u3092\u6301\u305f\u308c\u308b\u65b9\u304c\u697d", "variants": []}, {"id": 68, "text": "\u53ef\u611b\u3044\u3088\u308a\u683c\u597d\u3044\u3044\u304c\u597d\u304d\uff1f", "hint": "\u30d3\u30b8\u30e5\u30a2\u30eb\u3084\u30ad\u30e3\u30e9\u30af\u30bf\u30fc\u306e\u96f0\u56f2\u6c17\u3068\u3057\u3066", "variants": []}, {"id": 69, "text": "\u30cf\u30c3\u30d4\u30fc\u30a8\u30f3\u30c9\u3088\u308a\u5f8c\u5473\u304c\u6b8b\u308b\u7d42\u308f\u308a\u65b9\u304c\u597d\u304d\uff1f", "hint": "\u30d0\u30c3\u30c9\u30a8\u30f3\u30c9\u30fb\u9b31\u5c55\u958b\u30fb\u5f8c\u6094\u304c\u6b8b\u308b\u7d50\u672b\u304c\u597d\u304d", "variants": []}, {"id": 70, "text": "\u5927\u52e2\u3088\u308a\u4e00\u5bfe\u4e00\u304c\u597d\u304d\uff1f", "hint": "\u4e09\u89d2\u95a2\u4fc2\u3088\u308a\u4e00\u5bfe\u4e00\u306e\u6df1\u3044\u95a2\u4fc2\u304c\u597d\u304d", "variants": []}, {"id": 71, "text": "\u591c\u578b\u3067\u3059\u304b\uff1f", "hint": "\u4f8b\uff1a\u591c\u9045\u304f\u307e\u3067\u6d3b\u52d5\u3059\u308b\u30fb\u671d\u304c\u82e6\u624b\u306a\u30bf\u30a4\u30d7\uff1f", "variants": []}, {"id": 72, "text": "\u732b\u6d3e\u3067\u3059\u304b\uff1f", "hint": "\u4f8b\uff1a\u732b\u306e\u72ec\u7acb\u3057\u305f\u6027\u683c\u3084\u6c17\u307e\u3050\u308c\u3055\u304c\u597d\u304d\uff1f", "variants": []}, {"id": 73, "text": "\u5b89\u5b9a\u3088\u308a\u523a\u6fc0\u30fb\u5909\u5316\u304c\u597d\u304d\uff1f", "hint": "\u4f8b\uff1a\u5b89\u5b9a\u3057\u305f\u65e5\u5e38\u3088\u308a\u5909\u5316\u30fb\u30cf\u30d7\u30cb\u30f3\u30b0\u3092\u597d\u3080\uff1f", "variants": []}, {"id": 74, "text": "\u6c7a\u3081\u3089\u308c\u308b\u3088\u308a\u6c7a\u3081\u3066\u3082\u3089\u3046\u65b9\u304c\u697d\uff1f", "hint": "\u4f8b\uff1a\u4f55\u3092\u98df\u3079\u308b\u304b\u30fb\u3069\u3053\u3078\u884c\u304f\u304b\u3001\u6c7a\u3081\u3066\u3082\u3089\u3044\u305f\u3044\uff1f", "variants": []}, {"id": 75, "text": "\u6ce3\u3051\u308b\u8a71\u3088\u308a\u8208\u596e\u3059\u308b\u8a71\u304c\u597d\u304d\uff1f", "hint": "\u6ce3\u3051\u308b\u611f\u52d5\u8a71\u3088\u308a\u30d0\u30c8\u30eb\u30fb\u30b9\u30ea\u30eb\u306e\u3042\u308b\u8a71\u304c\u597d\u304d", "variants": []}, {"id": 76, "text": "\u5ac9\u59ac\u3057\u3084\u3059\u3044\uff1f", "hint": "\u604b\u611b\u3084\u53cb\u60c5\u3067\u5ac9\u59ac\u5fc3\u3092\u611f\u3058\u3084\u3059\u3044", "variants": []}, {"id": 77, "text": "\u8ab0\u304b\u306b\u72ec\u308a\u5360\u3081\u3055\u308c\u305f\u3044\u30fb\u307e\u305f\u306f\u3057\u305f\u3044\uff1f", "hint": "\u8ab0\u304b\u306b\u7279\u5225\u306b\u72ec\u5360\u3055\u308c\u305f\u3044\u3001\u307e\u305f\u306f\u72ec\u5360\u3057\u305f\u3044", "variants": []}, {"id": 78, "text": "\u79d8\u5bc6\u306e\u95a2\u4fc2\u306b\u60f9\u304b\u308c\u308b\uff1f", "hint": "\u516c\u306b\u306f\u8a00\u3048\u306a\u3044\u95a2\u4fc2\u30fb\u79d8\u5bc6\u306b\u3057\u3066\u308b\u95a2\u4fc2", "variants": []}, {"id": 79, "text": "\u30db\u30e9\u30fc\u306f\u5f97\u610f\uff1f", "hint": "\u4f8b\uff1a\u30db\u30e9\u30fc\u6620\u753b\u30fb\u602a\u8ac7\u30fb\u5fc3\u970a\u8a71\u304c\u5e73\u6c17\u30fb\u307e\u305f\u306f\u597d\u304d\uff1f", "variants": []}, {"id": 80, "text": "\u5f37\u3044\u4eba\u306b\u5b88\u3089\u308c\u305f\u3044\uff1f", "hint": "\u5f37\u304f\u3066\u983c\u308c\u308b\u76f8\u624b\u306b\u5b88\u3063\u3066\u3082\u3089\u3044\u305f\u3044", "variants": []}, {"id": 81, "text": "\u611f\u60c5\u3092\u8868\u306b\u51fa\u3055\u306a\u3044\u65b9\uff1f", "hint": "\u4f8b\uff1a\u611f\u60c5\u3092\u8868\u60c5\u3084\u8a00\u8449\u306b\u51fa\u3059\u3088\u308a\u5185\u306b\u6e9c\u3081\u8fbc\u3080\u65b9\uff1f", "variants": []}, {"id": 82, "text": "\u53e4\u5178\u30fb\u6b74\u53f2\u3088\u308a\u672a\u6765\u30fbSF\u7684\u306a\u3082\u306e\u304c\u597d\u304d\uff1f", "hint": "\u4f8b\uff1a\u6b74\u53f2\u3082\u306e\u30fb\u6642\u4ee3\u5287\u3088\u308a\u5b87\u5b99\u30fb\u672a\u6765\u30fbSF\u304c\u597d\u304d\uff1f", "variants": []}, {"id": 83, "text": "\u30eb\u30fc\u30eb\u3088\u308a\u6c17\u6301\u3061\u3092\u512a\u5148\u3059\u308b\u3053\u3068\u304c\u3042\u308b\uff1f", "hint": "\u4f8b\uff1a\u898f\u5247\u3084\u5e38\u8b58\u3088\u308a\u81ea\u5206\u306e\u6c17\u6301\u3061\u3092\u512a\u5148\u3059\u308b\u3053\u3068\u304c\u3042\u308b\uff1f", "variants": []}, {"id": 84, "text": "\u7518\u3048\u308b\u3088\u308a\u7518\u3048\u3055\u305b\u308b\u65b9\u304c\u597d\u304d\uff1f", "hint": "\u7518\u3048\u308b\uff08\u3055\u308c\u308b\uff09\u3088\u308a\u7518\u3048\u3055\u305b\u308b\uff08\u3059\u308b\uff09\u65b9\u304c\u597d\u304d", "variants": []}, {"id": 85, "text": "\u4e00\u4eba\u3067\u3044\u308b\u6642\u9593\u304c\u5fc5\u8981\uff1f", "hint": "\u4e00\u4eba\u3067\u3044\u308b\u6642\u9593\u304c\u5145\u96fb\u306b\u306a\u308b\u5185\u5411\u304d\u50be\u5411", "variants": []}, {"id": 86, "text": "\u30b5\u30d7\u30e9\u30a4\u30ba\u3088\u308a\u4e88\u5b9a\u901a\u308a\u304c\u597d\u304d\uff1f", "hint": "\u4f8b\uff1a\u30b5\u30d7\u30e9\u30a4\u30ba\u3088\u308a\u3042\u3089\u304b\u3058\u3081\u6c7a\u3081\u305f\u8a08\u753b\u306e\u65b9\u304c\u5b89\u5fc3\uff1f", "variants": []}, {"id": 87, "text": "\u300c\u3057\u3066\u306f\u3044\u3051\u306a\u3044\u300d\u3068\u3044\u3046\u611f\u899a\u306b\u60f9\u304b\u308c\u308b\uff1f", "hint": "\u300c\u3084\u3063\u3066\u306f\u3044\u3051\u306a\u3044\u300d\u3053\u3068\u3060\u304b\u3089\u3053\u305d\u60f9\u304b\u308c\u308b\u611f\u899a", "variants": []}, {"id": 88, "text": "\u5b88\u308b\u5074\u3068\u5b88\u3089\u308c\u308b\u5074\u306e\u975e\u5bfe\u79f0\u304c\u3042\u308b\u95a2\u4fc2\u304c\u597d\u304d\uff1f", "hint": "\u4f8b\uff1a\u9a0e\u58eb\u304c\u59eb\u3092\u5b88\u308b\u3001\u5e74\u4e0a\u304c\u5e74\u4e0b\u3092\u5e87\u3046", "variants": []}, {"id": 89, "text": "\u5b64\u72ec\u306a\u5b58\u5728\u304c\u8ab0\u304b\u3068\u7e4b\u304c\u308b\u95a2\u4fc2\u304c\u597d\u304d\uff1f", "hint": "\u4f8b\uff1a\u5b64\u72ec\u306a\u5438\u8840\u9b3c\u304c\u4eba\u9593\u3068\u51fa\u4f1a\u3046\u3001\u30a2\u30f3\u30c9\u30ed\u30a4\u30c9\u304c\u611f\u60c5\u3092\u77e5\u308b", "variants": []}, {"id": 90, "text": "\u904b\u547d\u30fb\u5fc5\u7136\u3092\u611f\u3058\u308b\u95a2\u4fc2\u304c\u597d\u304d\uff1f", "hint": "\u4f8b\uff1a\u524d\u4e16\u304b\u3089\u306e\u7e01\u3001\u8d64\u3044\u7cf8\u3001\u5bbf\u547d\u306e\u51fa\u4f1a\u3044", "variants": []}, {"id": 91, "text": "\u82e6\u3057\u3044\u306e\u306b\u96e2\u308c\u3089\u308c\u306a\u3044\u7a2e\u985e\u306e\u611b\u304c\u597d\u304d\uff1f", "hint": "\u4f8b\uff1a\u5171\u4f9d\u5b58\u3001\u546a\u3044\u306e\u3088\u3046\u306a\u611b\u3001\u5225\u308c\u3089\u308c\u306a\u3044", "variants": []}, {"id": 92, "text": "\u75db\u307f\u3084\u82e6\u3057\u307f\u304c\u5909\u5316\u30fb\u6210\u9577\u306b\u7e4b\u304c\u308b\u306e\u304c\u597d\u304d\uff1f", "hint": "\u4f8b\uff1a\u8a66\u7df4\u3092\u4e57\u308a\u8d8a\u3048\u3066\u5f37\u304f\u306a\u308b\u3001\u82e6\u3057\u307f\u304c\u7d46\u3092\u6df1\u3081\u308b", "variants": []}, {"id": 93, "text": "\u88cf\u793e\u4f1a\u30fb\u5371\u967a\u306a\u7d44\u7e54\u306b\u5c5e\u3059\u308b\u30ad\u30e3\u30e9\u3068\u306e\u604b\u611b\u304c\u597d\u304d\uff1f", "hint": "\u4f8b\uff1a\u30e4\u30af\u30b6\u30fb\u30de\u30d5\u30a3\u30a2\u30fb\u88cf\u7d44\u7e54\u306e\u30ad\u30e3\u30e9\u3068\u306e\u7981\u65ad\u306e\u604b", "variants": ["\u30de\u30d5\u30a3\u30a2\u30fb\u30e4\u30af\u30b6\u30fb\u88cf\u7d44\u7e54\u306e\u4eba\u7269\u3068\u306e\u604b\u611b\u306b\u60f9\u304b\u308c\u308b\uff1f"]}, {"id": 94, "text": "\u5bae\u5ef7\u30fb\u5f8c\u5bae\u30fb\u8cb4\u65cf\u793e\u4f1a\u306e\u6a29\u529b\u4e89\u3044\u304c\u80cc\u666f\u306b\u3042\u308b\u306e\u304c\u597d\u304d\uff1f", "hint": "\u4f8b\uff1a\u5f8c\u5bae\u3067\u306e\u8b00\u7565\u30fb\u8eab\u5206\u5dee\u306e\u3042\u308b\u5bae\u5ef7\u30ed\u30de\u30f3\u30b9\u30fb\u9670\u8b00\u3068\u604b\u611b\u306e\u7d61\u307f\u5408\u3044", "variants": ["\u5f8c\u5bae\u30fb\u5bae\u5ef7\u3092\u821e\u53f0\u306b\u3057\u305f\u6a29\u529b\u3068\u604b\u611b\u306e\u7d61\u307f\u5408\u3044\u304c\u597d\u304d\uff1f"]}, {"id": 95, "text": "\u540c\u3058\u6642\u9593\u30fb\u5834\u9762\u3092\u7e70\u308a\u8fd4\u3059\u30bf\u30a4\u30e0\u30eb\u30fc\u30d7\u304c\u597d\u304d\uff1f", "hint": "\u4f8b\uff1a\u30eb\u30fc\u30d7\u3059\u308b\u305f\u3073\u306b\u6df1\u307e\u308b\u60f3\u3044\u30fb\u8a18\u61b6\u306f\u81ea\u5206\u3060\u3051\u3068\u3044\u3046\u5207\u306a\u3055", "variants": ["\u30bf\u30a4\u30e0\u30eb\u30fc\u30d7\u30fb\u6642\u9593\u3092\u7e70\u308a\u8fd4\u3059\u8a2d\u5b9a\u304c\u597d\u304d\uff1f"]}, {"id": 96, "text": "\u5371\u6a5f\u7684\u72b6\u6cc1\u304b\u3089\u52a9\u3051\u3089\u308c\u30fb\u62fe\u308f\u308c\u3001\u5b88\u3063\u3066\u304f\u308c\u308b\u76f8\u624b\u306b\u60f9\u304b\u308c\u308b\u5c55\u958b\u304c\u597d\u304d\uff1f", "hint": "\u4f8b\uff1a\u8def\u982d\u306b\u8ff7\u3063\u305f\u6240\u3092\u52a9\u3051\u3066\u3082\u3089\u3046\u30fb\u4fdd\u8b77\u8005\u7684\u306a\u76f8\u624b\u3078\u306e\u4f9d\u5b58\u3068\u611b\u60c5", "variants": ["\u62fe\u308f\u308c\u7cfb\u30fb\u4fdd\u8b77\u3057\u3066\u304f\u308c\u305f\u76f8\u624b\u3068\u306e\u604b\u611b\u304c\u597d\u304d\uff1f"]}, {"id": 97, "text": "\u79d8\u5bc6\u306e\u7d20\u9854\u30fb\u4e8c\u91cd\u751f\u6d3b\u3092\u6301\u3064\u76f8\u624b\uff08\u30b9\u30d1\u30a4\u30fb\u8adc\u5831\u54e1\u306a\u3069\uff09\u3068\u306e\u604b\u304c\u597d\u304d\uff1f", "hint": "\u4f8b\uff1a\u30b9\u30d1\u30a4\u30fb\u30a8\u30fc\u30b8\u30a7\u30f3\u30c8\u30fb\u5b9f\u306f\u5225\u306e\u9854\u3092\u6301\u3064\u30ad\u30e3\u30e9\u3068\u306e\u5371\u967a\u306a\u604b", "variants": ["\u30b9\u30d1\u30a4\u30fb\u4e8c\u91cd\u751f\u6d3b\u3092\u9001\u308b\u30ad\u30e3\u30e9\u3068\u306e\u604b\u611b\u304c\u597d\u304d\uff1f"]}, {"id": 98, "text": "\u507d\u308a\u306e\u95a2\u4fc2\uff08\u507d\u88c5\u30fb\u5951\u7d04\uff09\u304b\u3089\u59cb\u307e\u308b\u604b\u611b\u304c\u597d\u304d\uff1f", "hint": "\u4f8b\uff1a\u507d\u88c5\u30ab\u30c3\u30d7\u30eb\u30fb\u5951\u7d04\u7d50\u5a5a\u30fb\u5618\u304b\u3089\u30b9\u30bf\u30fc\u30c8\u3057\u3066\u672c\u7269\u306b\u306a\u308b", "variants": ["\u507d\u88c5\u604b\u4eba\u30fb\u5951\u7d04\u7d50\u5a5a\u304b\u3089\u672c\u7269\u306e\u604b\u306b\u767a\u5c55\u3059\u308b\u5c55\u958b\u304c\u597d\u304d\uff1f"]}, {"id": 99, "text": "\u8b0e\u89e3\u304d\u30fb\u30df\u30b9\u30c6\u30ea\u30fc\u304c\u604b\u611b\u306b\u7d61\u3080\u5c55\u958b\u304c\u597d\u304d\uff1f", "hint": "\u4f8b\uff1a\u63a2\u5075\u30fb\u63a8\u7406\u30fb\u8b0e\u3092\u5171\u306b\u89e3\u304f\u30d1\u30fc\u30c8\u30ca\u30fc\u3068\u306e\u77e5\u7684\u306a\u604b\u611b", "variants": ["\u63a2\u5075\u30fb\u8b0e\u89e3\u304d\u30fb\u30df\u30b9\u30c6\u30ea\u30fc\u304c\u604b\u611b\u3068\u7d61\u3080\u8a2d\u5b9a\u304c\u597d\u304d\uff1f"]}, {"id": 100, "text": "\u5916\u898b\u306f\u6016\u3044\u30fb\u5f37\u9762\u3060\u304c\u5b9f\u306f\u512a\u3057\u3044\u30ad\u30e3\u30e9\u3068\u306e\u604b\u304c\u597d\u304d\uff1f", "hint": "\u4f8b\uff1a\u30e4\u30f3\u30ad\u30fc\u30fb\u4e0d\u826f\u30fb\u898b\u305f\u76ee\u30ae\u30e3\u30c3\u30d7\u3067\u81ea\u5206\u306b\u3060\u3051\u7518\u3044\u76f8\u624b", "variants": ["\u4e0d\u826f\u30fb\u30e4\u30f3\u30ad\u30fc\u306a\u3069\u5916\u898b\u3068\u4e2d\u8eab\u306e\u30ae\u30e3\u30c3\u30d7\u304c\u3042\u308b\u76f8\u624b\u3068\u306e\u604b\u304c\u597d\u304d\uff1f"]}, {"id": 101, "text": "\u4ed5\u4e8b\u4e00\u7b4b\u30fb\u6709\u80fd\u3060\u304c\u604b\u611b\u306b\u4e0d\u5668\u7528\u306a\u30ad\u30e3\u30e9\u304c\u597d\u304d\uff1f", "hint": "\u4f8b\uff1a\u793e\u755c\u30fb\u30a8\u30ea\u30fc\u30c8\u30fb\u6709\u80fd\u3059\u304e\u3066\u604b\u611b\u3060\u3051\u304c\u82e6\u624b\u306a\u30ad\u30e3\u30e9", "variants": ["\u4ed5\u4e8b\u4eba\u9593\u30fb\u30a8\u30ea\u30fc\u30c8\u304c\u521d\u3081\u3066\u604b\u3092\u77e5\u308b\u5c55\u958b\u304c\u597d\u304d\uff1f"]}, {"id": 102, "text": "\u4e92\u3044\u306b\u60f3\u3044\u5408\u3044\u306a\u304c\u3089\u3082\u3059\u308c\u9055\u3044\u7d9a\u3051\u308b\u3082\u3069\u304b\u3057\u3044\u5c55\u958b\u304c\u597d\u304d\uff1f", "hint": "\u4f8b\uff1a\u4e21\u7247\u601d\u3044\u30fb\u4f1d\u3048\u3089\u308c\u306a\u3044\u60f3\u3044\u30fb\u3059\u308c\u9055\u3044\u304c\u7d9a\u304f\u3058\u308c\u3063\u305f\u3055", "variants": ["\u4e21\u7247\u601d\u3044\u306e\u3059\u308c\u9055\u3044\u304c\u597d\u304d\uff1f"]}, {"id": 103, "text": "\u8ee2\u6821\u3084\u521d\u5bfe\u9762\u304b\u3089\u59cb\u307e\u308b\u9752\u6625\u306e\u521d\u604b\u304c\u597d\u304d\uff1f", "hint": "\u4f8b\uff1a\u8ee2\u6821\u751f\u3068\u306e\u51fa\u4f1a\u3044\u30fb\u521d\u3081\u3066\u60f9\u304b\u308c\u308b\u6c17\u6301\u3061\u30fb\u7518\u9178\u3063\u3071\u3044\u9752\u6625\u604b\u611b", "variants": []}, {"id": 104, "text": "\u546a\u3044\u30fb\u9b54\u6cd5\u7684\u306a\u5951\u7d04\u30fb\u4ee3\u511f\u306b\u7e1b\u3089\u308c\u305f\u5bbf\u547d\u7684\u306a\u95a2\u4fc2\u304c\u597d\u304d\uff1f", "hint": "\u4f8b\uff1a\u9b54\u6cd5\u306e\u8a93\u7d04\u30fb\u546a\u3044\u3067\u96e2\u308c\u3089\u308c\u306a\u3044\u30fb\u4ee3\u511f\u3092\u6255\u3046\u3053\u3068\u3067\u7d50\u3070\u308c\u305f\u95a2\u4fc2", "variants": []}]